# MinIO Configuration
MINIO_ROOT_USER: minio
MINIO_ROOT_PASSWORD: CHANGE_ME_MINIO_PASSWORD
MINIO_SERVER_URL: http://localhost:9000
MINIO_BROWSER_REDIRECT_URL: http://localhost:9001

# MySQL Configuration
MYSQL_ROOT_PASSWORD: CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE: im

# Web Configuration
API_URL=http://octo-server:8090

# 实名认证:Aegis OIDC 直切(YUJ-382 / Aegis OIDC Phase 1,2026-05-10)
# -----------------------------------------------------------------
# 旧链路(dmwork-verify-service + HMAC /v1/internal/verification/complete +
# HS256 /v1/internal/verify-token)已整体废弃,下列 env 不再需要,已从本文件删除:
#   OCTO_INTERNAL_HMAC_SECRET / OCTO_JWT_SECRET / OCTO_VERIFY_URL_BASE
#   OCTO_VERIFY_RETURN_TO_DEFAULT
# 新链路:Aegis IdP 下发 identity_verification scope claims → OIDC callback
# 直接 upsert user_verification。配置见 DM_OIDC_PROVIDER_* / DM_OIDC_AEGIS_*。
#
# ⚠️ scopes 显式配置(YUJ-389 / Aegis P1-3)
# -----------------------------------------------------------------
# dmworkim 默认 Scopes 已去掉 Aegis 私有的 "identity_verification",
# 回归通用 OIDC core scopes(openid / profile / email / phone / offline_access),
# 这样切 Keycloak / Auth0 / Okta 等严格 IdP 不会 invalid_scope 被拒。
#
# 因此 Aegis 部署必须显式配 scopes(两个 env 任选其一,PROVIDER 优先):
#   DM_OIDC_PROVIDER_SCOPES=openid,profile,email,phone,offline_access,identity_verification
# 或过渡 alias:
#   DM_OIDC_AEGIS_SCOPES=openid,profile,email,phone,offline_access,identity_verification
#
# 不配的话 Aegis 不会下发 is_verified / verified_at / legal_name 等 claim,
# 登录仍然能成功,但 callback 跳过 user_verification upsert(静默,不报错)。
